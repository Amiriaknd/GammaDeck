{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GammaDeck",
  "version": "0.1.0",
  "identifier": "com.gammadeck.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GammaDeck",
        "width": 800,
        "height": 380,
        "minWidth": 800,
        "minHeight": 380,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
